<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/hospitalsTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hospitals_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#F5F5F5" />

    <EditText
        android:id="@+id/hospitalSearchInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/hospitalsTitleText"
        android:layout_margin="12dp"
        android:padding="12dp"
        android:hint="@string/hospital_search_hint"
        android:inputType="text"
        android:background="#FFFFFF"
        android:drawablePadding="8dp"
        android:elevation="2dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/hospitalsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/hospitalSearchInput"
        android:padding="8dp" />

</RelativeLayout>
