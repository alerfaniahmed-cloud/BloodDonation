<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/circle_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/joinCreateLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_circle_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/circleNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/circle_name_hint"
                android:inputType="text"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/createCircleButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/create_circle_button"
                android:layout_marginBottom="28dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/join_circle_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/joinCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/circle_code_hint"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/joinCircleButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/join_circle_button" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/circleInfoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/circleNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/inviteCodeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:gravity="center"
                android:textColor="#1FAE8E"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/shareCodeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/share_invite_code_button"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/emergencyCircleButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/circle_emergency_button"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/circle_members_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/membersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/emptyMembersText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/empty_circle_members"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/leaveCircleButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/leave_circle_button"
                android:textColor="#D32F2F"
                android:backgroundTint="#FFEBEE"
                android:layout_marginTop="20dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
