<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/helpCasesTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/help_cases_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#F5F5F5" />

    <TextView
        android:id="@+id/charityDisclaimerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/helpCasesTitleText"
        android:text="@string/charity_disclaimer"
        android:textSize="12sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/helpCasesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/charityDisclaimerText"
        android:layout_above="@id/createHelpCaseButton"
        android:padding="8dp" />

    <TextView
        android:id="@+id/emptyHelpCasesText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/empty_help_cases"
        android:textSize="16sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/createHelpCaseButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="@string/create_help_case_button"
        android:padding="16dp" />

</RelativeLayout>
